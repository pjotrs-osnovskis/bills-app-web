PORT=3000
NODE_ENV=development
SESSION_SECRET=generate-a-long-random-string-for-production

# In production, set NODE_ENV=production so API and UI omit operator-only hints (SMTP, .env, server log).
# Optional override: CLIENT_DEV_HINTS=true forces those hints on; CLIENT_DEV_HINTS=false forces them off.
# CLIENT_DEV_HINTS=

GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Required for Google Drive OAuth callback — set to your actual app URL (no trailing slash)
APP_URL=http://localhost:3000

# Option A (production / Render / Railway): paste the full service account JSON as a single-line string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Option B (local dev): path to the service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=path/to/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/firebase-service-account.json

# Optional: override data/upload dirs (Cloud Run: use tmp or omit for ephemeral)
# BILLS_APP_DATA_DIR=./data
# BILLS_APP_UPLOADS_DIR=./public/uploads

# Outgoing email (Nodemailer) — required for “Send to customer” with PDF attachment
# SMTP_FROM must be a valid address your provider allows you to send as
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=invoices@example.com
